{
  "manifest_version": 3,
  "name": "Parsian Pro Trader",
  "version": "2.0",
  "host_permissions": [
    "https://patris.parsianbroker.com/*",
    "https://red.parsianbroker.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://patris.parsianbroker.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["ui.html", "ui.css", "ui.js"],
      "matches": ["https://patris.parsianbroker.com/*"]
    }
  ]
}
